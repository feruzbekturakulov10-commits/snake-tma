<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
<title>🐍 Змейка</title>
<script src="https://telegram.org/js/telegram-web-app.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
  :root{
    --green:#00ff88; --green2:#00cc66; --green3:#008844;
    --dark:#080812; --dark2:#0d0d1e; --dark3:#12122a;
    --red:#ff3355; --gold:#ffd700;
    --easy:#00ccff; --normal:#00ff88; --hard:#ff4422;
  }
  body{
    background:var(--dark);
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    min-height:100vh; overflow:hidden;
    font-family:'Press Start 2P', monospace;
    color:var(--green); touch-action:none;
  }
  #hud{
    width:100%; max-width:420px;
    display:flex; justify-content:space-between; align-items:center;
    padding:6px 14px;
    background:var(--dark2);
    border-bottom:2px solid var(--green3);
    font-size:9px;
  }
  #canvas-wrap{
    position:relative; width:100%; max-width:420px;
    flex:1; display:flex; align-items:center; justify-content:center;
    overflow:hidden;
  }
  canvas{display:block; image-rendering:pixelated; background:var(--dark);}
  .overlay{
    position:absolute; inset:0;
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    background:rgba(4,4,16,0.92);
    gap:12px; overflow-y:auto; padding:10px 0;
  }
  .overlay.hidden{display:none;}
  .overlay h1{
    font-size:clamp(16px,5vw,26px);
    color:var(--green);
    text-shadow:0 0 20px var(--green);
    text-align:center; line-height:1.6;
  }
  .btn{
    padding:10px 22px;
    background:var(--green3); color:#fff;
    font-family:inherit; font-size:9px;
    border:2px solid var(--green);
    cursor:pointer; border-radius:4px;
    box-shadow:0 0 12px var(--green3);
    transition:all .15s; letter-spacing:1px;
  }
  .btn:active{transform:scale(0.95);}

  /* Выбор сложности */
  .diff-btns{display:flex; gap:10px; flex-wrap:wrap; justify-content:center;}
  .diff-btn{
    padding:12px 18px;
    font-family:'Press Start 2P',monospace;
    font-size:9px; border-radius:6px;
    cursor:pointer; border:2px solid;
    transition:all .2s; text-align:center; line-height:1.8;
  }
  .diff-btn.easy{
    background:rgba(0,200,255,0.1);
    border-color:var(--easy); color:var(--easy);
  }
  .diff-btn.normal{
    background:rgba(0,255,136,0.1);
    border-color:var(--normal); color:var(--normal);
  }
  .diff-btn.hard{
    background:rgba(255,68,34,0.1);
    border-color:var(--hard); color:var(--hard);
  }
  .diff-btn:active{transform:scale(0.95);}
  .diff-btn.selected{filter:brightness(1.4); transform:scale(1.05);}

  .diff-desc{font-size:7px; color:#667; text-align:center; line-height:2;}

  /* Таблица лидеров */
  .leaderboard{
    width:280px; max-height:200px; overflow-y:auto;
  }
  .lb-row{
    display:flex; justify-content:space-between; align-items:center;
    padding:5px 8px; margin:3px 0;
    border-radius:4px; border-left:2px solid #223;
    background:rgba(255,255,255,0.03);
  }
  .lb-row.gold{border-color:#ffd700; background:rgba(255,215,0,0.08);}
  .lb-row.silver{border-color:#aaa; background:rgba(170,170,170,0.06);}
  .lb-row.bronze{border-color:#cd7f32; background:rgba(205,127,50,0.06);}

  /* Таб навигация */
  .tabs{display:flex; gap:0; margin-bottom:4px;}
  .tab{
    padding:6px 14px; font-family:inherit; font-size:7px;
    background:var(--dark3); color:#556;
    border:1px solid #223; cursor:pointer;
    transition:all .15s;
  }
  .tab.active{background:var(--green3); color:#fff; border-color:var(--green);}
  .tab:first-child{border-radius:4px 0 0 4px;}
  .tab:last-child{border-radius:0 4px 4px 0;}

  /* D-Pad */
  #dpad{
    width:100%; max-width:420px;
    display:grid;
    grid-template-columns:repeat(3,1fr);
    grid-template-rows:repeat(2,1fr);
    gap:6px; padding:8px 14px 12px;
    background:var(--dark2);
    border-top:2px solid var(--green3);
  }
  .dpad-btn{
    background:var(--dark3); border:1.5px solid #223;
    border-radius:6px; color:var(--green);
    font-size:20px;
    display:flex; align-items:center; justify-content:center;
    padding:9px; cursor:pointer; user-select:none;
    transition:background .1s;
  }
  .dpad-btn:active,.dpad-btn.pressed{background:#1a2a1a;border-color:var(--green3);}
  .dpad-btn.empty{visibility:hidden;}
  #btn-up{grid-column:2;grid-row:1;}
  #btn-left{grid-column:1;grid-row:2;}
  #btn-down{grid-column:2;grid-row:2;}
  #btn-right{grid-column:3;grid-row:2;}

  #score-popup{
    position:absolute; font-size:13px;
    color:var(--gold); text-shadow:0 0 8px var(--gold);
    pointer-events:none; font-family:'Press Start 2P',monospace;
    opacity:0; transition:opacity .1s;
  }

  /* Бейдж сложности в HUD */
  #diff-badge{
    font-size:7px; padding:2px 6px;
    border-radius:3px; border:1px solid;
    letter-spacing:1px;
  }
</style>
</head>
<body>

<!-- HUD -->
<div id="hud">
  <div style="display:flex;align-items:center;gap:8px;">
    <div id="current-fruit-icon" style="font-size:16px;">🍎</div>
    <div>
      <div style="color:#555;font-size:6px;margin-bottom:2px;">СЧЁТ</div>
      <div id="score-val" style="color:#fff;font-size:11px;">0</div>
    </div>
  </div>
  <div id="diff-badge">EASY</div>
  <div style="text-align:right;">
    <div style="color:#555;font-size:6px;margin-bottom:2px;">РЕКОРД</div>
    <div id="best-val" style="color:#888;font-size:9px;">0</div>
  </div>
</div>

<!-- Игровое поле -->
<div id="canvas-wrap">
  <canvas id="c"></canvas>
  <div id="score-popup">+2</div>

  <!-- Стартовый экран -->
  <div class="overlay" id="screen-start">
    <h1>🐍 ЗМЕЙКА</h1>

    <div style="font-size:8px;color:#556;">ВЫБЕРИТЕ СЛОЖНОСТЬ</div>

    <div class="diff-btns">
      <div class="diff-btn easy" onclick="selectDiff('easy')">
        EASY<br>
        <span style="font-size:6px;opacity:0.7;">Без стен • Медленно</span>
      </div>
      <div class="diff-btn normal selected" onclick="selectDiff('normal')">
        NORMAL<br>
        <span style="font-size:6px;opacity:0.7;">Стены • Средне</span>
      </div>
      <div class="diff-btn hard" onclick="selectDiff('hard')">
        HARD<br>
        <span style="font-size:6px;opacity:0.7;">Стены+ • Быстро</span>
      </div>
    </div>

    <div class="diff-desc" id="diff-desc">Стены убивают • Средняя скорость</div>

    <button class="btn" id="btn-start">▶ ИГРАТЬ</button>
    <div id="best-display" style="font-size:7px;color:#555;"></div>
  </div>

  <!-- Экран конца игры -->
  <div class="overlay hidden" id="screen-dead">
    <h1 style="color:var(--red);text-shadow:0 0 20px var(--red);">КОНЕЦ!</h1>
    <div style="font-size:8px;color:#aaa;">СЧЁТ: <span id="final-score" style="color:#fff;">0</span></div>
    <div id="new-record" style="color:var(--gold);font-size:8px;display:none;">🏆 НОВЫЙ РЕКОРД!</div>

    <!-- Табы: История / Лидеры -->
    <div class="tabs">
      <div class="tab active" id="tab-history" onclick="switchTab('history')">МОИ ИГРЫ</div>
      <div class="tab" id="tab-leaders" onclick="switchTab('leaders')">ЛИДЕРЫ</div>
    </div>

    <div class="leaderboard" id="panel-history"></div>
    <div class="leaderboard hidden" id="panel-leaders"></div>

    <div style="display:flex;gap:10px;">
      <button class="btn" id="btn-restart">↺ ЕЩЁ РАЗ</button>
      <button class="btn" style="background:#1a0a22;border-color:#555;color:#999;font-size:8px;"
        onclick="selectDiff(currentDiff);show('screen-start')">⚙ МЕНЮ</button>
    </div>
  </div>
</div>

<!-- D-Pad -->
<div id="dpad">
  <div class="dpad-btn empty"></div>
  <div class="dpad-btn" id="btn-up">▲</div>
  <div class="dpad-btn empty"></div>
  <div class="dpad-btn" id="btn-left">◀</div>
  <div class="dpad-btn" id="btn-down">▼</div>
  <div class="dpad-btn" id="btn-right">▶</div>
</div>

<script>
const tg = window.Telegram?.WebApp;
if(tg){ tg.ready(); tg.expand(); tg.setHeaderColor('#080812'); }

// ── Canvas ───────────────────────────────────────────────────────────────────
const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');
const CELL = 20;
let COLS, ROWS, W, H;

function resizeCanvas(){
  const wrap = document.getElementById('canvas-wrap');
  const maxW = Math.min(wrap.clientWidth, 420);
  COLS = Math.floor(maxW / CELL);
  ROWS = Math.floor(wrap.clientHeight / CELL);
  W = COLS*CELL; H = ROWS*CELL;
  canvas.width = W; canvas.height = H;
}
resizeCanvas();
window.addEventListener('resize', resizeCanvas);

// ── Сложность ────────────────────────────────────────────────────────────────
const DIFFICULTIES = {
  easy:   { speed:200, walls:false, wallCount:0,  label:'EASY',   color:'#00ccff' },
  normal: { speed:130, walls:true,  wallCount:6,  label:'NORMAL', color:'#00ff88' },
  hard:   { speed:75,  walls:true,  wallCount:14, label:'HARD',   color:'#ff4422' },
};
let currentDiff = 'normal';
let wallTiles = [];

function selectDiff(d){
  currentDiff = d;
  document.querySelectorAll('.diff-btn').forEach(b=>b.classList.remove('selected'));
  document.querySelector('.diff-btn.'+d).classList.add('selected');
  const descs = {
    easy:   'Проходишь сквозь стены • Медленно',
    normal: 'Стены убивают • Средняя скорость',
    hard:   'Много стен • Очень быстро • x2 очки'
  };
  document.getElementById('diff-desc').textContent = descs[d];
  // Рекорд для этой сложности
  const best = getBest(d);
  document.getElementById('best-display').textContent = best > 0 ? '🏆 Рекорд ('+d.toUpperCase()+'): '+best : '';
}

// ── Хранилище ─────────────────────────────────────────────────────────────────
function getBest(d){ return parseInt(localStorage.getItem('snake_best_'+d)||'0'); }
function setBest(d,v){ localStorage.setItem('snake_best_'+d, String(v)); }
function getHistory(d){ return JSON.parse(localStorage.getItem('snake_hist_'+d)||'[]'); }
function setHistory(d,h){ localStorage.setItem('snake_hist_'+d, JSON.stringify(h)); }
function getLeaders(){ return JSON.parse(localStorage.getItem('snake_leaders')||'[]'); }
function setLeaders(l){ localStorage.setItem('snake_leaders', JSON.stringify(l)); }

function saveResult(score){
  const d = currentDiff;
  // Личный рекорд
  if(score > getBest(d)) setBest(d, score);
  // История
  if(score > 0){
    const now = new Date();
    const hist = getHistory(d);
    hist.unshift({
      score, diff:d,
      date: now.toLocaleDateString('ru-RU'),
      time: now.toLocaleTimeString('ru-RU',{hour:'2-digit',minute:'2-digit'})
    });
    setHistory(d, hist.slice(0,10));
    // Общая таблица лидеров
    const leaders = getLeaders();
    const name = tg?.initDataUnsafe?.user?.first_name || 'Игрок';
    leaders.push({name, score, diff:d, date:now.toLocaleDateString('ru-RU')});
    leaders.sort((a,b)=>b.score-a.score);
    setLeaders(leaders.slice(0,10));
  }
}

// ── Фрукты ───────────────────────────────────────────────────────────────────
const FRUITS = [
  {icon:'🍎',pts:1,color:'#cc2222'},{icon:'🍌',pts:1,color:'#ffdd00'},
  {icon:'🥝',pts:2,color:'#5a9a20'},{icon:'🍇',pts:2,color:'#8822bb'},
  {icon:'🍓',pts:1,color:'#dd1133'},{icon:'🍊',pts:1,color:'#ff7700'},
  {icon:'🍉',pts:2,color:'#228822'},{icon:'🍋',pts:1,color:'#ffdd00'},
  {icon:'🍑',pts:1,color:'#ffaa66'},{icon:'🫐',pts:2,color:'#334499'},
];

// ── Состояние игры ────────────────────────────────────────────────────────────
let snake, dir, nextDir, food, fruitObj, score;
let gameRunning=false, animId=null, lastTime=0;
let currentSpeed = 130;

function startGame(){
  resizeCanvas();
  const cfg = DIFFICULTIES[currentDiff];
  currentSpeed = cfg.speed;

  // Обновляем HUD бейдж
  const badge = document.getElementById('diff-badge');
  badge.textContent = cfg.label;
  badge.style.color = cfg.color;
  badge.style.borderColor = cfg.color;

  // Генерируем стены (для normal/hard)
  wallTiles = [];
  if(cfg.walls){
    let attempts = 0;
    while(wallTiles.length < cfg.wallCount && attempts < 500){
      attempts++;
      const wx = Math.floor(Math.random()*COLS);
      const wy = Math.floor(Math.random()*ROWS);
      // Не ставим стену в центре (стартовая позиция змейки)
      const cx = Math.floor(COLS/2), cy = Math.floor(ROWS/2);
      if(Math.abs(wx-cx)<4 && Math.abs(wy-cy)<4) continue;
      if(!wallTiles.find(w=>w.x===wx&&w.y===wy))
        wallTiles.push({x:wx,y:wy});
    }
  }

  snake = [{x:Math.floor(COLS/2), y:Math.floor(ROWS/2)}];
  dir = {x:1,y:0}; nextDir = {x:1,y:0};
  score = 0;
  spawnFood();
  updateHUD();
  gameRunning = true;
  lastTime = 0;
  cancelAnimationFrame(animId);
  loop(0);
}

function spawnFood(){
  fruitObj = FRUITS[Math.floor(Math.random()*FRUITS.length)];
  document.getElementById('current-fruit-icon').textContent = fruitObj.icon;
  let pos;
  do{
    pos = {x:Math.floor(Math.random()*COLS), y:Math.floor(Math.random()*ROWS)};
  } while(
    snake.some(s=>s.x===pos.x&&s.y===pos.y) ||
    wallTiles.some(w=>w.x===pos.x&&w.y===pos.y)
  );
  food = pos;
}

function updateHUD(){
  document.getElementById('score-val').textContent = score;
  document.getElementById('best-val').textContent = getBest(currentDiff);
}

// ── Игровой цикл ──────────────────────────────────────────────────────────────
function loop(ts){
  animId = requestAnimationFrame(loop);
  if(ts - lastTime < currentSpeed) return;
  lastTime = ts;
  tick(); render();
}

function tick(){
  dir = {...nextDir};
  let nx = snake[0].x + dir.x;
  let ny = snake[0].y + dir.y;

  const cfg = DIFFICULTIES[currentDiff];
  if(cfg.walls){
    // Стены убивают
    if(nx<0||nx>=COLS||ny<0||ny>=ROWS){ gameOver(); return; }
  } else {
    // Проходим сквозь стены (easy)
    nx = (nx+COLS)%COLS;
    ny = (ny+ROWS)%ROWS;
  }

  // Столкновение с собой
  if(snake.slice(0,-1).some(s=>s.x===nx&&s.y===ny)){ gameOver(); return; }
  // Столкновение с блоком стены
  if(wallTiles.some(w=>w.x===nx&&w.y===ny)){ gameOver(); return; }

  const head = {x:nx, y:ny};
  snake.unshift(head);

  if(head.x===food.x&&head.y===food.y){
    // Hard даёт x2 очки
    const pts = fruitObj.pts * (currentDiff==='hard' ? 2 : 1);
    score += pts;
    showPopup(food.x*CELL+CELL/2, food.y*CELL, '+'+pts);
    spawnFood();
    updateHUD();
  } else {
    snake.pop();
  }
}

// ── Рендер ────────────────────────────────────────────────────────────────────
function render(){
  const cfg = DIFFICULTIES[currentDiff];
  // Фон
  ctx.fillStyle = currentDiff==='hard' ? '#0a0608' : '#080812';
  ctx.fillRect(0,0,W,H);

  // Сетка
  ctx.strokeStyle = currentDiff==='hard' ? '#1a0e10' : '#0e0e22';
  ctx.lineWidth=0.5;
  for(let x=0;x<W;x+=CELL){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();}
  for(let y=0;y<H;y+=CELL){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}

  // Стены
  drawWalls();
  drawFood();
  drawSnake();

  // Граница поля для hard
  if(currentDiff==='hard'){
    ctx.strokeStyle='#ff4422'; ctx.lineWidth=2;
    ctx.strokeRect(1,1,W-2,H-2);
    ctx.strokeStyle='rgba(255,68,34,0.3)'; ctx.lineWidth=4;
    ctx.strokeRect(3,3,W-6,H-6);
  }
}

function drawWalls(){
  if(wallTiles.length===0) return;
  wallTiles.forEach(w=>{
    const x=w.x*CELL, y=w.y*CELL;
    // Основной блок
    const grad = ctx.createLinearGradient(x,y,x+CELL,y+CELL);
    if(currentDiff==='hard'){
      grad.addColorStop(0,'#662211'); grad.addColorStop(1,'#331108');
    } else {
      grad.addColorStop(0,'#334455'); grad.addColorStop(1,'#1a2233');
    }
    ctx.fillStyle=grad;
    ctx.fillRect(x+1,y+1,CELL-2,CELL-2);
    // Блик
    ctx.fillStyle= currentDiff==='hard' ? 'rgba(255,100,60,0.3)' : 'rgba(100,160,220,0.2)';
    ctx.fillRect(x+2,y+2,CELL-4,4);
    // Контур
    ctx.strokeStyle= currentDiff==='hard' ? '#883322' : '#445566';
    ctx.lineWidth=1;
    ctx.strokeRect(x+1,y+1,CELL-2,CELL-2);
    // Символ
    ctx.fillStyle= currentDiff==='hard' ? '#ff6644' : '#667788';
    ctx.font='bold 11px monospace';
    ctx.textAlign='center'; ctx.textBaseline='middle';
    ctx.fillText('▪', x+CELL/2, y+CELL/2);
  });
}

function drawFood(){
  const cx=food.x*CELL+CELL/2, cy=food.y*CELL+CELL/2;
  const pulse=0.5+0.5*Math.sin(Date.now()*0.006);
  const r=CELL*0.42+pulse*2.5;
  const grd=ctx.createRadialGradient(cx,cy,0,cx,cy,r+8);
  grd.addColorStop(0, fruitObj.color+'99');
  grd.addColorStop(1,'transparent');
  ctx.fillStyle=grd; ctx.beginPath(); ctx.arc(cx,cy,r+8,0,Math.PI*2); ctx.fill();
  ctx.font=`${Math.round(r*1.8)}px serif`;
  ctx.textAlign='center'; ctx.textBaseline='middle';
  ctx.fillText(fruitObj.icon, cx, cy+1);
}

function drawSnake(){
  const n = snake.length;
  if(n<1) return;
  const pts = snake.map(s=>({x:s.x*CELL+CELL/2, y:s.y*CELL+CELL/2}));

  // Цвет змейки зависит от сложности
  const headColors = {
    easy:  ['#44ddff','#00aacc','#005588'],
    normal:['#4eff91','#00ee77','#006633'],
    hard:  ['#ff8844','#ff4422','#881100'],
  }[currentDiff];

  for(let i=n-1;i>=0;i--){
    const t = i/Math.max(n-1,1);
    const r = Math.max(3,(CELL/2-1)*(1-t*0.5));
    const {x,y} = pts[i];

    // Тень
    ctx.fillStyle='rgba(0,0,0,0.35)';
    ctx.beginPath(); ctx.ellipse(x+1,y+2,r,r*0.7,0,0,Math.PI*2); ctx.fill();

    if(i===0){
      // ── Голова ──
      const dx=dir.x, dy=dir.y;
      const rx=r+Math.abs(dx)*3, ry=r+Math.abs(dy)*3;

      // Свечение
      const grd=ctx.createRadialGradient(x,y,0,x,y,rx+6);
      grd.addColorStop(0,headColors[0]+'44');
      grd.addColorStop(1,'transparent');
      ctx.fillStyle=grd;
      ctx.beginPath(); ctx.ellipse(x,y,rx+6,ry+6,0,0,Math.PI*2); ctx.fill();

      // Тело головы
      const hGrd=ctx.createRadialGradient(x-rx*0.3,y-ry*0.3,0,x,y,rx);
      hGrd.addColorStop(0,headColors[0]);
      hGrd.addColorStop(0.5,headColors[1]);
      hGrd.addColorStop(1,headColors[2]);
      ctx.fillStyle=hGrd;
      ctx.strokeStyle=headColors[2]; ctx.lineWidth=1.5;
      ctx.beginPath(); ctx.ellipse(x,y,rx,ry,0,0,Math.PI*2);
      ctx.fill(); ctx.stroke();

      // Паттерн чешуи на голове
      ctx.fillStyle='rgba(255,255,255,0.1)';
      ctx.beginPath(); ctx.ellipse(x,y,rx*0.6,ry*0.6,0,0,Math.PI*2); ctx.fill();

      // Глаза
      const ex1=x+dx*5+dy*(r-3), ey1=y+dy*5-dx*(r-3);
      const ex2=x+dx*5-dy*(r-3), ey2=y+dy*5+dx*(r-3);
      [[ex1,ey1],[ex2,ey2]].forEach(([ex,ey])=>{
        // Белок
        ctx.fillStyle='#ddfff0';
        ctx.beginPath(); ctx.arc(ex,ey,3.5,0,Math.PI*2); ctx.fill();
        // Зрачок вертикальный (как у змеи)
        ctx.fillStyle='#0a0a00';
        ctx.beginPath(); ctx.ellipse(ex+dx*0.5,ey+dy*0.5,1,2,Math.atan2(dy,dx),0,Math.PI*2); ctx.fill();
        // Блик
        ctx.fillStyle='white';
        ctx.beginPath(); ctx.arc(ex-0.5,ey-0.5,0.8,0,Math.PI*2); ctx.fill();
      });

      // Ноздри
      const nx1=x+dx*(rx-2)+dy*2, ny1=y+dy*(ry-2)-dx*2;
      const nx2=x+dx*(rx-2)-dy*2, ny2=y+dy*(ry-2)+dx*2;
      ctx.fillStyle=headColors[2];
      ctx.beginPath(); ctx.arc(nx1,ny1,1.5,0,Math.PI*2); ctx.fill();
      ctx.beginPath(); ctx.arc(nx2,ny2,1.5,0,Math.PI*2); ctx.fill();

      // Язык
      const tx=x+dx*(rx+2), ty=y+dy*(ry+2);
      ctx.strokeStyle='#ff1155'; ctx.lineWidth=2.5; ctx.lineCap='round';
      ctx.beginPath(); ctx.moveTo(x+dx*rx,y+dy*ry); ctx.lineTo(tx,ty); ctx.stroke();
      ctx.lineWidth=1.5;
      ctx.beginPath(); ctx.moveTo(tx,ty); ctx.lineTo(tx+dx*5+dy*4,ty+dy*5-dx*4); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(tx,ty); ctx.lineTo(tx+dx*5-dy*4,ty+dy*5+dx*4); ctx.stroke();

    } else {
      // ── Тело ──
      const c1=lerpColor(headColors[0],headColors[2],t*0.9);
      const c2=lerpColor(headColors[1],headColors[2],t);
      const g=ctx.createRadialGradient(x-r*0.3,y-r*0.3,0,x,y,r);
      g.addColorStop(0,c1); g.addColorStop(1,c2);
      ctx.fillStyle=g;
      ctx.strokeStyle=lerpColor(headColors[2],'#000000',0.5);
      ctx.lineWidth=1;
      ctx.beginPath(); ctx.arc(x,y,r,0,Math.PI*2);
      ctx.fill(); ctx.stroke();

      // Чешуйки через сегмент
      if(i%2===0 && r>5){
        const sr=r*0.5;
        ctx.fillStyle='rgba(255,255,255,0.08)';
        ctx.beginPath(); ctx.ellipse(x,y,sr,sr*0.55,0,0,Math.PI*2); ctx.fill();
        // Линия по краю чешуйки
        ctx.strokeStyle='rgba(255,255,255,0.06)';
        ctx.lineWidth=0.5;
        ctx.beginPath(); ctx.ellipse(x,y,sr,sr*0.55,0,0,Math.PI*2); ctx.stroke();
      }

      // Хребет (центральная линия)
      if(r>6){
        ctx.fillStyle='rgba(255,255,255,0.12)';
        ctx.beginPath(); ctx.arc(x,y,r*0.18,0,Math.PI*2); ctx.fill();
      }
    }
  }
}

function lerpColor(c1,c2,t){
  const r1=parseInt(c1.slice(1,3),16),g1=parseInt(c1.slice(3,5),16),b1=parseInt(c1.slice(5,7),16);
  const r2=parseInt(c2.slice(1,3),16),g2=parseInt(c2.slice(3,5),16),b2=parseInt(c2.slice(5,7),16);
  const r=Math.round(r1+(r2-r1)*t),g=Math.round(g1+(g2-g1)*t),b=Math.round(b1+(b2-b1)*t);
  return '#'+[r,g,b].map(v=>v.toString(16).padStart(2,'0')).join('');
}

// ── Попап очков ───────────────────────────────────────────────────────────────
let popupTimer=null;
function showPopup(x,y,text){
  const el=document.getElementById('score-popup');
  el.textContent=text; el.style.left=x+'px'; el.style.top=y+'px';
  el.style.opacity='1'; el.style.transform='translateY(0)'; el.style.transition='none';
  clearTimeout(popupTimer);
  requestAnimationFrame(()=>{
    el.style.transition='opacity .6s,transform .6s';
    el.style.opacity='0'; el.style.transform='translateY(-26px)';
  });
  popupTimer=setTimeout(()=>el.style.opacity='0',700);
}

// ── Конец игры ────────────────────────────────────────────────────────────────
function gameOver(){
  gameRunning=false;
  cancelAnimationFrame(animId);
  const wasRecord = score>0 && score>=getBest(currentDiff);
  saveResult(score);
  updateHUD();
  document.getElementById('final-score').textContent=score;
  document.getElementById('new-record').style.display=wasRecord?'block':'none';
  switchTab('history');
  show('screen-dead');
  if(tg?.HapticFeedback) tg.HapticFeedback.notificationOccurred('error');
}

// ── Таблицы ───────────────────────────────────────────────────────────────────
function switchTab(tab){
  document.getElementById('tab-history').classList.toggle('active', tab==='history');
  document.getElementById('tab-leaders').classList.toggle('active', tab==='leaders');
  document.getElementById('panel-history').classList.toggle('hidden', tab!=='history');
  document.getElementById('panel-leaders').classList.toggle('hidden', tab!=='leaders');
  if(tab==='history') renderHistory();
  else renderLeaders();
}

function renderHistory(){
  const el=document.getElementById('panel-history');
  const hist=getHistory(currentDiff);
  if(hist.length===0){
    el.innerHTML='<div style="color:#555;font-size:7px;text-align:center;padding:10px">Нет игр на этой сложности</div>';
    return;
  }
  const medals=['🥇','🥈','🥉'];
  el.innerHTML=hist.map((g,i)=>`
    <div class="lb-row ${i===0?'gold':i===1?'silver':i===2?'bronze':''}">
      <span style="font-size:10px">${medals[i]||('#'+(i+1))}</span>
      <span style="color:#fff;font-size:10px;font-weight:bold">${g.score}</span>
      <span style="color:#555;font-size:6px">${g.date} ${g.time}</span>
    </div>`).join('');
}

function renderLeaders(){
  const el=document.getElementById('panel-leaders');
  const leaders=getLeaders();
  if(leaders.length===0){
    el.innerHTML='<div style="color:#555;font-size:7px;text-align:center;padding:10px">Пока нет рекордов</div>';
    return;
  }
  const medals=['🥇','🥈','🥉'];
  const dColors={easy:'#00ccff',normal:'#00ff88',hard:'#ff4422'};
  el.innerHTML=leaders.map((g,i)=>`
    <div class="lb-row ${i===0?'gold':i===1?'silver':i===2?'bronze':''}">
      <span style="font-size:10px">${medals[i]||('#'+(i+1))}</span>
      <span style="color:#ddd;font-size:8px;max-width:80px;overflow:hidden">${g.name}</span>
      <span style="color:#fff;font-size:10px;font-weight:bold">${g.score}</span>
      <span style="color:${dColors[g.diff]||'#888'};font-size:6px">${(g.diff||'').toUpperCase()}</span>
    </div>`).join('');
}

// ── Экраны ────────────────────────────────────────────────────────────────────
function show(id){
  document.querySelectorAll('.overlay').forEach(el=>el.classList.add('hidden'));
  document.getElementById(id)?.classList.remove('hidden');
}
function hideOverlays(){
  document.querySelectorAll('.overlay').forEach(el=>el.classList.add('hidden'));
}

document.getElementById('btn-start').addEventListener('click',()=>{ hideOverlays(); startGame(); });
document.getElementById('btn-restart').addEventListener('click',()=>{ hideOverlays(); startGame(); });

// Инициализация стартового экрана
selectDiff('normal');
const best = getBest('normal');
if(best>0) document.getElementById('best-display').textContent='🏆 Рекорд: '+best;
updateHUD();

// ── Клавиатура ────────────────────────────────────────────────────────────────
document.addEventListener('keydown',e=>{
  if(!gameRunning) return;
  if(e.key==='ArrowUp'    && dir.y!==1)  nextDir={x:0,y:-1};
  if(e.key==='ArrowDown'  && dir.y!==-1) nextDir={x:0,y:1};
  if(e.key==='ArrowLeft'  && dir.x!==1)  nextDir={x:-1,y:0};
  if(e.key==='ArrowRight' && dir.x!==-1) nextDir={x:1,y:0};
});

// ── D-Pad ─────────────────────────────────────────────────────────────────────
function dpad(dx,dy){
  if(!gameRunning) return;
  if(dx===0&&dy===-1&&dir.y!==1)  nextDir={x:0,y:-1};
  if(dx===0&&dy===1&&dir.y!==-1)  nextDir={x:0,y:1};
  if(dx===-1&&dy===0&&dir.x!==1)  nextDir={x:-1,y:0};
  if(dx===1&&dy===0&&dir.x!==-1)  nextDir={x:1,y:0};
  if(tg?.HapticFeedback) tg.HapticFeedback.impactOccurred('light');
}
[['btn-up',0,-1],['btn-down',0,1],['btn-left',-1,0],['btn-right',1,0]].forEach(([id,dx,dy])=>{
  const btn=document.getElementById(id);
  btn.addEventListener('touchstart',e=>{e.preventDefault();dpad(dx,dy);btn.classList.add('pressed');},{passive:false});
  btn.addEventListener('touchend',()=>btn.classList.remove('pressed'));
  btn.addEventListener('mousedown',()=>dpad(dx,dy));
});

// ── Свайп ─────────────────────────────────────────────────────────────────────
let swipeX=0,swipeY=0;
canvas.addEventListener('touchstart',e=>{swipeX=e.touches[0].clientX;swipeY=e.touches[0].clientY;},{passive:true});
canvas.addEventListener('touchend',e=>{
  const dx=e.changedTouches[0].clientX-swipeX;
  const dy=e.changedTouches[0].clientY-swipeY;
  if(Math.abs(dx)>Math.abs(dy)){ if(dx>20)dpad(1,0);else if(dx<-20)dpad(-1,0); }
  else{ if(dy>20)dpad(0,1);else if(dy<-20)dpad(0,-1); }
},{passive:true});

ctx.fillStyle='#080812'; ctx.fillRect(0,0,W||300,H||300);
